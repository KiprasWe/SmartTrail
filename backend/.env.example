# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:CHANGE_ME@localhost:5432/smarttrail"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_ME"
JWT_EXPIRES_IN="15m"

# Google OAuth
GOOGLE_CLIENT_ID="CHANGE_ME.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="CHANGE_ME"

# Google Gemini AI
GEMINI_API_KEY="CHANGE_ME"

# Google Places API
GOOGLE_PLACES_API_KEY="CHANGE_ME"

# OpenRouteService (routing + POIs)
ORS_API_KEY="CHANGE_ME"

# Stadia Maps (Valhalla routing)
STADIA_API_KEY="CHANGE_ME"

# Cloudflare R2 (profile picture storage)
R2_ACCOUNT_ID="CHANGE_ME"
R2_ACCESS_KEY_ID="CHANGE_ME"
R2_SECRET_ACCESS_KEY="CHANGE_ME"
R2_BUCKET_NAME="CHANGE_ME"
R2_PUBLIC_URL="https://CHANGE_ME.r2.dev"

# CORS — comma-separated allowed origins (required in production)
# CORS_ORIGIN="https://your-app.com"

# Node environment: development | production
NODE_ENV="development"
