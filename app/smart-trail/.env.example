# Copy this file to .env and fill in real values.
# All EXPO_PUBLIC_ variables are bundled into the app binary - never put secrets here.

# Backend base URL (no trailing slash)
EXPO_PUBLIC_API_URL="http://localhost:5001"

# Google Sign-In client IDs (these are public identifiers, not secrets)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID="CHANGE_ME.apps.googleusercontent.com"
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID="CHANGE_ME.apps.googleusercontent.com"
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID="CHANGE_ME.apps.googleusercontent.com"